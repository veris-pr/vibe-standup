# Standup environment configuration
# Copy to ~/.standup/.env and fill in your values.
# This file is never committed — credentials stay local.

# ─── AWS (for Bedrock plugins) ───────────────────────────────────
# Option 1: Named profile (recommended — uses ~/.aws/credentials)
# AWS_PROFILE=my-profile

# Option 2: Explicit credentials (for CI or containers)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Region for Bedrock / Transcribe / S3
# AWS_DEFAULT_REGION=us-east-1

# S3 bucket for Amazon Transcribe (required for bedrock-transcribe plugin)
# STANDUP_S3_BUCKET=my-standup-bucket

# ─── Google Cloud (for Google plugins) ───────────────────────────
# GCP project ID (required for google-stt, google-llm, google-image-gen)
# GOOGLE_CLOUD_PROJECT=my-project-id

# Auth is handled by gcloud CLI — run `gcloud auth login` first.
# For service accounts, set:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── General ─────────────────────────────────────────────────────
# Override project root detection (for non-standard installs)
# STANDUP_PROJECT_ROOT=/path/to/standup
